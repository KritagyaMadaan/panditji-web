rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId);
    }

    // --- PANDITS COLLECTION ---
    match /pandits/{panditId} {
      // Everyone can browse pandits
      allow read: if true;
      
      // Only the pandit can manage their own profile
      allow create, update: if isOwner(panditId);
    }

    // --- SERVICES COLLECTION ---
    match /services/{serviceId} {
      // Publicly readable, restricted write access
      allow read: if true;
      allow write: if false; // Only manageable via Admin SDK/backend
    }

    // --- BOOKINGS COLLECTION ---
    match /bookings/{bookingId} {
      // Only the customer who made the booking OR the assigned pandit can read/write it
      allow read: if isSignedIn() && (
        resource.data.customerId == request.auth.uid || 
        resource.data.panditId == request.auth.uid
      );
      
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.customerId == request.auth.uid || 
        resource.data.panditId == request.auth.uid
      );
    }

    // Default deny for everything else
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
